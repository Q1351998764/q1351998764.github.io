<!DOCTYPE html>
<html lang="@PAGELANG@">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="@DESC@">
    <meta name="referrer" content="no-referrer">
    <link rel="icon" href="/static/favicon.ico">
    <title>@TITLE@ | @DESC@</title>
    <link rel="stylesheet" href="/static/pico.min.css">
    <link rel="stylesheet" href="/static/style.css">
</head>

<body>
    <main class="container">
        <header class="site-header">
            <h1>@TITLE@</h1>
            <nav class="site-nav" aria-label="Site">
                <a href="text">@T_MEMETXT@</a>
                <a href="manage/">@T_UPLOAD@</a>
            </nav>
        </header>

        <p id="description"></p>

        <section id="gallery-controls" aria-label="Gallery filters">
            <nav id="category-tabs" aria-label="Categories"></nav>
            <label id="sensitive-control" hidden>
                <input type="checkbox" id="show-sensitive" role="switch">
                @T_SENSITIVE@
            </label>
        </section>

        <article id="view" hidden>
            <header class="view-header">
                <div>
                    <h2 id="view-title"></h2>
                    <span id="view-category"></span>
                </div>
                <nav class="view-actions" aria-label="Entry actions">
                    <a id="view-download" download title="@T_DOWNLOAD@" class="icon-action">
                        <svg width="28" height="28" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"
                            fill="currentColor" aria-hidden="true">
                            <path
                                d="M5.36891 8.08074L7.50833 10.2202V4.46802H8.50833V10.1473L10.5749 8.08074L11.282 8.78784L8.32545 11.7444H7.61835L4.6618 8.78784L5.36891 8.08074Z" />
                            <path
                                d="M14 8C14 4.68629 11.3137 2 8 2C4.68629 2 2 4.68629 2 8C2 11.3137 4.68629 14 8 14C11.3137 14 14 11.3137 14 8ZM13 8C13 10.7614 10.7614 13 8 13C5.23858 13 3 10.7614 3 8C3 5.23858 5.23858 3 8 3C10.7614 3 13 5.23858 13 8Z" />
                        </svg>
                    </a>
                    <button id="refresh-btn" title="@T_ANOTHER@" class="icon-action" type="button">
                        <svg width="28" height="28" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"
                            fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" clip-rule="evenodd"
                                d="M4.681 3H2V2h3.5l.5.5V6H5V4a5 5 0 1 0 4.53-.761l.302-.954A6 6 0 1 1 4.681 3z" />
                        </svg>
                    </button>
                    <a href="#" title="@T_BACK@" class="icon-action">
                        <svg width="30" height="30" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"
                            fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" clip-rule="evenodd"
                                d="M8 8.707l3.646 3.647.708-.707L8.707 8l3.647-3.646-.707-.708L8 7.293 4.354 3.646l-.707.708L7.293 8l-3.646 3.646.707.708L8 8.707z" />
                        </svg>
                    </a>
                </nav>
            </header>

            <div id="view-sensitive-gate" hidden>
                <button id="reveal-sensitive" type="button">@T_SENSITIVE_HIDDEN@</button>
            </div>
            <div id="view-images"></div>
        </article>

        <section id="gallery-shell">
            <p id="empty-state" hidden>@T_EMPTY@</p>
            <div id="gallery">
                <div class="column" id="col1"></div>
                <div class="column" id="col2"></div>
                <div class="column" id="col3"></div>
            </div>
        </section>

        <footer id="footer">
            <p>@FOOTER@</p>
        </footer>
    </main>

    <template id="gallery-item">
        <article class="item">
            <a href="#">
                <div class="item-media">
                    <img alt="" loading="lazy">
                    <span class="item-count" hidden></span>
                </div>
                <span class="item-title"></span>
            </a>
        </article>
    </template>

    <template id="view-image">
        <figure class="view-image">
            <a target="_blank" rel="noopener noreferrer" title="@T_ZOOMIN@">
                <img alt="" loading="lazy">
            </a>
            <figcaption>
                <span></span>
                <a download title="@T_DOWNLOAD@">@T_DOWNLOAD@</a>
            </figcaption>
        </figure>
    </template>

    <script src="./static/scripts/index.js" type="module"></script>
</body>

</html>
