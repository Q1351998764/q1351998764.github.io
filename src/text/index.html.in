<!DOCTYPE html>
<html lang="@PAGELANG@">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="@DESC@">
    <meta name="referrer" content="no-referrer">
    <meta http-equiv="Content-Security-Policy"
        content="default-src 'self'; img-src 'self' https: data:; style-src 'self'; script-src 'self'; base-uri 'self'; form-action 'none'">
    <link rel="icon" href="/static/favicon.ico">
    <title>@TITLE@ | @T_MEMETXT@</title>
    <link rel="stylesheet" href="/static/pico.min.css">
    <link rel="stylesheet" href="/static/text.css?v=1">
</head>

<body>
    <main class="container text-shell">
        <header class="site-header">
            <h1>@TITLE@</h1>
            <nav class="site-nav" aria-label="Site">
                <a href="/">@T_MEMEPIC@</a>
                <a href="/manage/">@T_UPLOAD@</a>
            </nav>
        </header>

        <p id="text-description"></p>

        <section id="text-controls" aria-label="Text filters">
            <nav id="text-category-tabs" aria-label="Categories"></nav>
            <div id="text-options">
                <label id="text-sort-control" for="text-sort-order">
                    <span>@T_SORT@</span>
                    <select id="text-sort-order">
                        <option value="random">@T_SORT_RANDOM@</option>
                        <option value="newest">@T_SORT_NEWEST@</option>
                        <option value="oldest">@T_SORT_OLDEST@</option>
                    </select>
                </label>
                <label id="text-sensitive-control" hidden>
                    <input type="checkbox" id="text-show-sensitive" role="switch">
                    @T_SENSITIVE@
                </label>
            </div>
        </section>

        <section id="text-view" hidden>
            <header class="text-view-header">
                <div>
                    <h2 id="text-view-title"></h2>
                    <span id="text-view-meta"></span>
                </div>
                <button id="text-back-btn" class="secondary outline" type="button" title="@T_BACK@" aria-label="@T_BACK@">←</button>
            </header>
            <div id="text-sensitive-gate" hidden>
                <button id="text-reveal-sensitive" type="button">@T_SENSITIVE_HIDDEN@</button>
            </div>
            <div id="text-documents"></div>
        </section>

        <section id="text-gallery-shell">
            <p id="text-empty-state" hidden>@T_EMPTY@</p>
            <div id="text-gallery"></div>
        </section>

        <footer id="footer">
            <p>@FOOTER@</p>
        </footer>
    </main>

    <template id="text-card-template">
        <article class="text-card">
            <a href="#">
                <header>
                    <h2></h2>
                    <span class="text-card-category"></span>
                </header>
                <p class="text-card-excerpt"></p>
                <footer>
                    <time></time>
                    <span class="text-card-count" hidden></span>
                </footer>
            </a>
        </article>
    </template>

    <template id="text-document-template">
        <article class="text-document">
            <header>
                <h3></h3>
                <time></time>
            </header>
            <div class="markdown-body"></div>
        </article>
    </template>

    <script src="/static/vendor/marked.min.js"></script>
    <script src="/static/vendor/purify.min.js"></script>
    <script src="/static/scripts/text.js?v=1" type="module"></script>
</body>

</html>
