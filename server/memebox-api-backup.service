[Unit]
Description=Back up MemeBox SQLite database

[Service]
Type=oneshot
User=memebox
Group=memebox
WorkingDirectory=/opt/memebox-api
EnvironmentFile=/etc/memebox-api.env
ExecStart=/usr/bin/python3 /opt/memebox-api/backup.py
UMask=0027
NoNewPrivileges=true
PrivateDevices=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
StateDirectory=memebox-api
